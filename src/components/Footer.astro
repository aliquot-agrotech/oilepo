---
const year = new Date().getFullYear();
---
<footer id="site-footer">
  <div class="container">
    <!-- Brand -->
    <div class="footer-brand">
      <span class="footer-logo">OILEPO</span>
      <p class="footer-tagline">Luxury Safari Camps &middot; Kenya</p>
    </div>

    <!-- Social -->
    <div class="footer-social">
      <a href="https://www.facebook.com/oileporesorts/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-link fb">
        <!-- Facebook -->
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </a>
      <a href="https://www.instagram.com/oilepo_resorts/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link ig">
        <!-- Instagram -->
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4.5"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/company/101655006/admin/feed/posts/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-link li">
        <!-- LinkedIn -->
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
    </div>

    <!-- Copyright -->
    <div class="footer-copy">
      <p>Copyright &copy; {year} Oilepo. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  #site-footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem 1.5rem;
    background: var(--color-background);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-logo {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-text-dark);
  }

  .footer-tagline {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0;
    text-transform: uppercase;
  }

  .footer-social {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    transition: border-color 0.2s, color 0.2s;
    text-decoration: none;
  }

  .social-link.fb  { color: var(--color-social-fb); }
  .social-link.ig  { color: var(--color-social-ig); }
  .social-link.li  { color: var(--color-social-li); }

  .social-link:hover {
    border-color: currentColor;
  }

  .footer-copy {
    text-align: right;
  }

  .footer-copy p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-brand {
      align-items: center;
    }

    .footer-social {
      justify-content: center;
    }

    .footer-copy {
      text-align: center;
    }
  }
</style>
