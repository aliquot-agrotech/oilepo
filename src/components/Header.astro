---
const { pathname } = Astro.url;

const navLinks = [
  { href: '/',         label: 'Home' },
  { href: '/about',    label: 'About' },
  { href: '/amboseli', label: 'Oilepo Amboseli' },
  { href: '/naivasha', label: 'Oilepo Naivasha' },
  { href: '/gallery',  label: 'Photo Gallery' },
  { href: '/contact',  label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---
<header id="site-header">
  <nav class="nav-inner">
    <a href="/" class="logo-link" aria-label="Oilepo home">
      <img class="w-16" src="https://s3.oilepo.com//t/Oilepo/oilepo.png" alt="OILEPO">
    </a>

    <!-- Desktop nav -->
    <ul class="desktop-nav">
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} class:list={['nav-link', { active: isActive(href) }]}>
            {label}
          </a>
        </li>
      ))}
      <li><a href="/contact" class="btn-book">Book Now</a></li>
    </ul>

    <!-- Hamburger -->
    <button id="menu-toggle" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- Mobile overlay -->
  <div id="mobile-menu" aria-hidden="true">
    <button id="menu-close" aria-label="Close menu">&times;</button>
    <ul class="mobile-nav">
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} class:list={[{ 'mobile-active': isActive(href) }]}>
            {label}
          </a>
        </li>
      ))}
      <li><a href="/contact" class="mobile-btn-book">Book Now</a></li>
    </ul>
  </div>
</header>

<script>
  function setupMenu() {
    const toggle = document.getElementById('menu-toggle');
    const closeBtn = document.getElementById('menu-close');
    const menu = document.getElementById('mobile-menu');

    if (!toggle || !closeBtn || !menu) return;

    function openMenu() {
      menu?.classList.add('open');
      menu?.setAttribute('aria-hidden', 'false');
      toggle?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menu?.classList.remove('open');
      menu?.setAttribute('aria-hidden', 'true');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    menu.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
  }

  // Runs on initial load and after every View Transition navigation
  document.addEventListener('astro:page-load', setupMenu);
</script>

<style>
  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    /* No backdrop-filter here — it would make this a containing block
       for position:fixed children, breaking the full-screen mobile menu.
       The blur lives on ::before instead. */
    border-bottom: 1px solid var(--color-border);
  }

  #site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.72);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    backdrop-filter: blur(16px) saturate(180%);
    z-index: -1;
  }

  .nav-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .logo-link {
    text-decoration: none;
    flex-shrink: 0;
  }

  /* Desktop nav */
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text);
    padding: 0.5rem 0.75rem;
    transition: color 0.2s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-accent);
  }

  .btn-book {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: #fff;
    background: var(--color-accent);
    padding: 0.6rem 1.25rem;
    border-radius: 2px;
    margin-left: 0.5rem;
    transition: background 0.2s;
  }

  .btn-book:hover {
    background: var(--color-accent-hover);
  }

  /* Hamburger */
  #menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  #menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text-dark);
    border-radius: 2px;
    transition: all 0.2s;
  }

  /* Mobile overlay */
  #mobile-menu {
    position: fixed;
    inset: 0;
    background: var(--color-background);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    overflow-y: auto;
    padding: 6rem 1.5rem 3rem;
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  #mobile-menu.open {
    opacity: 1;
    pointer-events: all;
  }

  #menu-close {
    position: absolute;
    top: 1.5rem;
    right: 1.75rem;
    background: none;
    border: none;
    font-size: 2rem;
    line-height: 1;
    color: var(--color-text-dark);
    cursor: pointer;
  }

  .mobile-nav {
    width: 100%;
    list-style: none;
    margin: 0 auto;
    padding: 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .mobile-nav a {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--color-text-dark);
    transition: color 0.2s;
  }

  .mobile-nav a:hover,
  .mobile-nav a.mobile-active {
    color: var(--color-accent);
  }

  .mobile-btn-book {
    display: inline-block;
    font-family: var(--font-sans) !important;
    font-size: 0.8rem !important;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff !important;
    background: var(--color-accent);
    padding: 0.75rem 2rem;
    border-radius: 2px;
    transition: background 0.2s;
  }

  .mobile-btn-book:hover {
    background: var(--color-accent-hover);
  }

  /* Responsive */
  @media (max-width: 921px) {
    .desktop-nav {
      display: none;
    }

    #menu-toggle {
      display: flex;
    }
  }
</style>
