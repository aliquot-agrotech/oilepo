        caption: 'Main Dining Hall', 
        wide: true 
      },
      { 
        src:PUBLIC_STORAGE_URL+"/t/Oilepo/Website Photos/RR5H6435.jpg",
        alt: 'RR5H6260 — Bar and lounge area', 
        caption: 'Bar & Lounge' 
      },
      { 
        src:PUBLIC_STORAGE_URL+"/t/Oilepo/Website Photos/Restaurant.jpg",
        alt: 'TepStudios-180 — Outdoor dining terrace',
        caption: 'Outdoor Terrace' 
      },
      { 
        src:PUBLIC_STORAGE_URL+"/t/Oilepo/Website Photos/RR5H6242.jpg",
        alt: 'Amboseli National Park restaurant dining experience — sunset table',
