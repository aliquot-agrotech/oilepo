      },
      // { 
      //   src:PUBLIC_STORAGE_URL+"/t/Oilepo/Gallery/20260328_071910.jpg",
      //   alt: 'Tent at sunrise with mist', 
      //   caption: 'Morning Mist' 
      // },
    ],
  },
  {
    id: 'clubhouse',
    title: 'Clubhouse',
